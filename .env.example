# Docker Compose
VAULT_TOKEN=hvs.xxxxxxxxxxxxxxxxxxxxx

# Vault S3 storage backend (Wasabi)
VAULT_S3_ACCESS_KEY=
VAULT_S3_SECRET_KEY=

# AWS CLI (for DB backups/restores, same Wasabi creds)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Wasabi S3 (Thanos metrics + Loki logs)
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=

# Grafana
GRAFANA_ADMIN_PASSWORD=

# RabbitMQ (setup.sh)
RABBITMQ_PASS=

# PostgreSQL k8s user (setup.sh)
POSTGRES_K8S_PASS=

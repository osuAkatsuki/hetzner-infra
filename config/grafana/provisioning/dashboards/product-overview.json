{
  "uid": "product-overview",
  "title": "Akatsuki Product Overview",
  "tags": ["product"],
  "timezone": "utc",
  "refresh": "1m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Online Users (now)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "redis-datasource", "uid": "redis" },
      "targets": [
        {
          "command": "scard",
          "keyName": "peppy:online_users",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "dark-red" },
              { "value": 10, "color": "yellow" },
              { "value": 50, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Active Donors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as active_donors FROM users WHERE donor_expire > UNIX_TIMESTAMP() AND donor_expire != 2147483647 AND privileges & 4",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "super-light-purple" }
        }
      }
    },
    {
      "id": 3,
      "title": "Monthly Recurring Revenue",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) * 5 as mrr FROM users WHERE donor_expire > UNIX_TIMESTAMP() AND donor_expire != 2147483647 AND privileges & 4",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Registered Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as total_users FROM users WHERE privileges & 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Scores (ranked)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as total FROM scores WHERE completed = 3",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      }
    },
    {
      "id": 6,
      "title": "Total Achievements Unlocked",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as total FROM users_achievements",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "yellow" }
        }
      }
    },
    {
      "id": 10,
      "title": "Score Submissions by Mode",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT FROM_UNIXTIME(t.h * 3600) as time, t.mode as metric, t.count as value FROM (SELECT FLOOR(time / 3600) as h, CASE play_mode WHEN 0 THEN 'std' WHEN 1 THEN 'taiko' WHEN 2 THEN 'ctb' WHEN 3 THEN 'mania' END as mode, COUNT(*) as count FROM scores WHERE time >= UNIX_TIMESTAMP(NOW() - INTERVAL 7 DAY) AND completed = 3 GROUP BY FLOOR(time / 3600), play_mode) t ORDER BY time",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 11,
      "title": "Achievements Unlocked by Mode",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT FROM_UNIXTIME(t.h * 3600) as time, t.mode as metric, t.count as value FROM (SELECT FLOOR(created_at / 3600) as h, CASE mode WHEN 0 THEN 'std' WHEN 1 THEN 'taiko' WHEN 2 THEN 'ctb' WHEN 3 THEN 'mania' END as mode, COUNT(*) as count FROM users_achievements WHERE created_at >= UNIX_TIMESTAMP(NOW() - INTERVAL 7 DAY) GROUP BY FLOOR(created_at / 3600), mode) t ORDER BY time",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 12,
      "title": "New User Registrations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT FROM_UNIXTIME(t.d * 86400) as time, t.registrations FROM (SELECT FLOOR(register_datetime / 86400) as d, COUNT(*) as registrations FROM users WHERE register_datetime >= UNIX_TIMESTAMP(NOW() - INTERVAL 90 DAY) AND privileges & 1 GROUP BY FLOOR(register_datetime / 86400)) t ORDER BY time",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "scheme"
          },
          "color": { "mode": "fixed", "fixedColor": "semi-dark-green" },
          "unit": "short",
          "displayName": "Signups/day"
        }
      }
    },
    {
      "id": 13,
      "title": "Donor Subscription MRR Timeline",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT month_start as time, COUNT(*) * 5 as mrr_usd FROM (SELECT 0 n UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9 UNION SELECT 10 UNION SELECT 11) months CROSS JOIN LATERAL (SELECT DATE_FORMAT(NOW() - INTERVAL months.n MONTH, '%Y-%m-01 00:00:00') as month_start) d CROSS JOIN LATERAL (SELECT id FROM users WHERE donor_expire >= UNIX_TIMESTAMP(d.month_start) AND donor_expire != 2147483647 AND privileges & 4) u GROUP BY month_start ORDER BY month_start",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "pointSize": 8,
            "showPoints": "always"
          },
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "currencyUSD",
          "displayName": "MRR"
        }
      }
    },
    {
      "id": 14,
      "title": "Active Users (last 24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as dau FROM users WHERE latest_activity >= UNIX_TIMESTAMP(NOW() - INTERVAL 1 DAY) AND privileges & 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "light-blue" }
        }
      }
    },
    {
      "id": 15,
      "title": "Active Users (last 7d)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as wau FROM users WHERE latest_activity >= UNIX_TIMESTAMP(NOW() - INTERVAL 7 DAY) AND privileges & 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "light-blue" }
        }
      }
    },
    {
      "id": 16,
      "title": "Active Users (last 30d)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as mau FROM users WHERE latest_activity >= UNIX_TIMESTAMP(NOW() - INTERVAL 30 DAY) AND privileges & 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "light-blue" }
        }
      }
    },
    {
      "id": 17,
      "title": "Top Achievements (last 7d)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT a.name as achievement, COUNT(*) as unlocks FROM users_achievements ua JOIN achievements a ON a.id = ua.achievement_id WHERE ua.created_at >= UNIX_TIMESTAMP(NOW() - INTERVAL 7 DAY) GROUP BY ua.achievement_id, a.name ORDER BY unlocks DESC LIMIT 15",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 18,
      "title": "Score Submissions by Mode (last 7d)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT CASE play_mode WHEN 0 THEN 'osu!std' WHEN 1 THEN 'osu!taiko' WHEN 2 THEN 'osu!ctb' WHEN 3 THEN 'osu!mania' END as mode, COUNT(*) as count FROM scores WHERE time >= UNIX_TIMESTAMP(NOW() - INTERVAL 7 DAY) AND completed = 3 GROUP BY play_mode ORDER BY count DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 19,
      "title": "Active Multiplayer Matches (last 7d)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as matches FROM matches WHERE start_time >= NOW() - INTERVAL 7 DAY",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "light-purple" }
        }
      }
    },
    {
      "id": 20,
      "title": "Donor Expiry Distribution",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "mysql", "uid": "mysql" },
      "targets": [
        {
          "rawSql": "SELECT SUM(CASE WHEN donor_expire > UNIX_TIMESTAMP() AND donor_expire <= UNIX_TIMESTAMP() + 86400*30 THEN 1 ELSE 0 END) as 'Expiring <30d', SUM(CASE WHEN donor_expire > UNIX_TIMESTAMP() + 86400*30 THEN 1 ELSE 0 END) as 'Expiring >30d' FROM users WHERE privileges & 4 AND donor_expire > UNIX_TIMESTAMP()",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "light-green" }
        }
      }
    }
  ],
  "schemaVersion": 39
}
